-- 10. MAIN LOOP
RunService.RenderStepped:Connect(function()
    local char = Player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart
    local hum = char:FindFirstChild("Humanoid")

    -- NOCLIP
    if flyOn or stickyTpOn then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end
    
    -- STICKY TP
    if stickyTpOn and tpTargetPlayer and tpTargetPlayer.Character and tpTargetPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local targetHrp = tpTargetPlayer.Character.HumanoidRootPart
        hrp.CFrame = targetHrp.CFrame
        hrp.Velocity = Vector3.new(0, 0, 0)
    elseif stickyTpOn then
        stickyTpOn = false
        tpTargetPlayer = nil
        tpPlayerBtn.Text = "TP PLAYER: OFF"
        tpPlayerS.Color = Color3.fromRGB(60, 60, 80)
    end

    if hrp.Position.Y < 5 then waterPart.CFrame = CFrame.new(hrp.Position.X, 0, hrp.Position.Z) else waterPart.CFrame = CFrame.new(0, -500, 0) end

    if aimOn then
        local target = nil
        local dist = 150
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("Model") and v:FindFirstChild("Humanoid") and v ~= char then
                if v:FindFirstChild("HumanoidRootPart") and v.Humanoid.Health > 0 then
                    local d = (hrp.Position - v.HumanoidRootPart.Position).Magnitude
                    if d < dist then target = v.HumanoidRootPart dist = d end
                end
            end
        end
        if target then Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Position) end
    end

    if tracking and currentTarget and currentTarget:FindFirstChild("HumanoidRootPart") then
        hrp.CFrame = currentTarget.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
        if currentTarget.Humanoid.Health <= 0 then tracking = false killBtn.Text = "AUTO KILL: OFF" end
    end

    if ghostOn then
        Camera.CFrame = CFrame.new(Camera.CFrame.Position) * CFrame.fromEulerAnglesYXZ(rotY, rotX, 0)
        local mv = ControlModule:GetMoveVector()
        Camera.CFrame = Camera.CFrame + (Camera.CFrame.LookVector * -mv.Z + Camera.CFrame.RightVector * mv.X) * 2
    elseif flyOn then
        local mv = ControlModule:GetMoveVector()
        hrp.Velocity = Vector3.new(0,0,0)
        local lookAtCFrame = CFrame.new(hrp.Position) * Camera.CFrame.Rotation
        hrp.CFrame = lookAtCFrame + (Camera.CFrame.LookVector * -mv.Z + Camera.CFrame.RightVector * mv.X) * getFlySpeed()
    end
    if speedOn then hum.WalkSpeed = 16 * getWalkSpeed() else hum.WalkSpeed = 16 end
end)

-- DRAGGING
local dragging, dragStart, startPos
topBar.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true dragStart = input.Position startPos = mainContainer.Position end end)
UserInputService.InputChanged:Connect(function(input) 
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        mainContainer.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    elseif ghostOn and input.UserInputType == Enum.UserInputType.Touch and input.Position.X > (Camera.ViewportSize.X / 2) then
        rotX = rotX - input.Delta.X * 0.005
        rotY = math.clamp(rotY - input.Delta.Y * 0.005, -1.4, 1.4)
    end
end)
UserInputService.InputEnded:Connect(function() dragging = false end)
