-- 5. HILFSFUNKTIONEN
local function createSlider(parent, defaultValue, minVal, maxVal, order)
    local sliderFrame = Instance.new("Frame", parent)
    sliderFrame.Size = UDim2.new(1, 0, 0, 25)
    sliderFrame.BackgroundTransparency = 1
    sliderFrame.Visible = false
    sliderFrame.LayoutOrder = order
    local bg = Instance.new("Frame", sliderFrame)
    bg.Size = UDim2.new(1, -20, 0, 4)
    bg.Position = UDim2.new(0, 10, 0.5, -2)
    bg.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    Instance.new("UICorner", bg)
    local fill = Instance.new("Frame", bg)
    fill.Size = UDim2.new((defaultValue - minVal)/(maxVal - minVal), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
    Instance.new("UICorner", fill)
    local knob = Instance.new("Frame", sliderFrame)
    knob.Size = UDim2.new(0, 14, 0, 14)
    knob.Position = UDim2.new(fill.Size.X.Scale, -7, 0.5, -7)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    local currentVal = defaultValue
    local function update(input)
        local pos = math.clamp((input.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
        fill.Size = UDim2.new(pos, 0, 1, 0)
        knob.Position = UDim2.new(pos, -7, 0.5, -7)
        currentVal = minVal + (pos * (maxVal - minVal))
    end
    local dragging = false
    knob.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true end end)
    UserInputService.InputEnded:Connect(function() dragging = false end)
    UserInputService.InputChanged:Connect(function(input) if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then update(input) end end)
    return sliderFrame, function() return currentVal end
end

